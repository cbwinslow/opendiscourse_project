# OpenDiscourse Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Database
# ============================================
# Use existing PostgreSQL on host
# For Docker: use host.docker.internal instead of localhost
DATABASE_URL=postgresql+asyncpg://cbwinslow:password@localhost:5432/opendiscourse
DATABASE_URL_SYNC=postgresql+psycopg2://cbwinslow:password@localhost:5432/opendiscourse

# ============================================
# Redis (for Celery)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# Congress.gov API
# Get key at: https://api.data.gov/signup
# ============================================
CONGRESS_GOV_API_KEY=

# ============================================
# GovInfo API
# Uses same api.data.gov key as Congress.gov
# ============================================
GOVINFO_API_KEY=

# ============================================
# FEC Campaign Finance API
# Get key at: https://api.open.fec.gov/developers/
# ============================================
FEC_API_KEY=

# ============================================
# OpenSecrets API
# Get key at: https://www.opensecrets.org/api/
# ============================================
OPENSECRETS_API_KEY=

# ============================================
# Finnhub (Congressional Trading)
# Get key at: https://finnhub.io/
# ============================================
FINNHUB_API_KEY=

# ============================================
# Financial Modeling Prep (Congressional Trading)
# Get key at: https://financialmodelingprep.com/
# ============================================
FMP_API_KEY=

# ============================================
# Apify (Stock Disclosures Scraping)
# Get key at: https://apify.com/
# ============================================
APIFY_API_TOKEN=

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# Ingestion Settings
# ============================================
# Number of concurrent API requests
INGESTION_CONCURRENCY=5
# Batch size for database inserts
INGESTION_BATCH_SIZE=1000
# Rate limit delay (seconds) between requests
INGESTION_RATE_LIMIT_DELAY=0.1
